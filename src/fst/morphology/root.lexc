! Particle ;		  !!â‰ˆ * @CODE@
 Postposition ;	  !!â‰ˆ * @CODE@
 Preposition ;	  !!â‰ˆ * @CODE@
 Pronoun ;		  !!â‰ˆ * @CODE@
  @U.Cap.Obl@  ProperNoun          ; ! SME proper nouns - always uppercase
  @U.Cap.Opt@  ProperNoun          ; ! SME proper nouns - downcased for derivations
 Punctuation ;	  !!â‰ˆ * @CODE@
 Symbols     ;	  !!â‰ˆ * @CODE@
 VerbRoot ;		  !!â‰ˆ * @CODE@
 Subjunction ;	  !!â‰ˆ * @CODE@
 Symbols ;
 Abbreviation ;
